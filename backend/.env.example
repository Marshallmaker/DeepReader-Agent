# ========================
# DeepReader Agent — 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# ========================

# Database Configuration
DATABASE_URL=mysql+pymysql://root:YOUR_PASSWORD@localhost:3306/deepreader_db

# JWT Configuration
# 生成方式: openssl rand -hex 32
SECRET_KEY=YOUR_SECRET_KEY_GENERATED_BY_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# SiliconFlow API Configuration
# 获取地址: https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=sk-YOUR_SILICONFLOW_API_KEY
SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Pro/deepseek-ai/DeepSeek-V3.2

# File Upload Configuration
MAX_UPLOAD_FILES=10
MAX_FILE_SIZE_MB=20
UPLOAD_DIR=uploads

# Rate Limiting
CHAT_RATE_LIMIT=10
CHAT_RATE_WINDOW=60

# Email Configuration (SMTP)
SMTP_SERVER=smtp.163.com
SMTP_PORT=587
SMTP_USERNAME=your_email@163.com
SMTP_PASSWORD=YOUR_SMTP_AUTH_CODE
SMTP_SENDER_NAME=DeepReader
# sandbox 模式开启时将邮件写入 /logs/mock_mails/ 而非真实发送
MAIL_SANDBOX_MODE=true
