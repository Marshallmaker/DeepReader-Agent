{
  "permissions": {
    "allow": [
      "Bash(pkill -f \"uvicorn app.main\")",
      "Bash(curl -s http://127.0.0.1:8000/health)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"[System.Console]::Beep(1000, 300)\"",
            "shell": "powershell",
            "async": true
          }
        ]
      }
    ]
  }
}
